<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AutoShorts — Viral Video Machine</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://accounts.google.com/gsi/client" async defer></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{--bg:#08080c;--bg2:#101018;--card:#14141e;--border:#1e1e30;--fg:#e8e8ec;--muted:#6b6b80;--accent:#ff3b30;--accent2:#ff5545;--glow:rgba(255,59,48,.25);--success:#30d158;--warn:#ff9f0a}
*{margin:0;padding:0;box-sizing:border-box;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--fg);overflow:hidden;height:100vh}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.nav-item{display:flex;align-items:center;gap:12px;padding:10px 16px;border-radius:10px;cursor:pointer;transition:.2s;color:var(--muted);font-weight:500;font-size:14px}
.nav-item:hover{background:rgba(255,255,255,.04);color:var(--fg)}
.nav-item.active{background:var(--glow);color:var(--accent);font-weight:600}
.btn-primary{background:var(--accent);color:#fff;border:none;padding:12px 24px;border-radius:10px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;transition:.2s;display:inline-flex;align-items:center;gap:8px}
.btn-primary:hover{background:var(--accent2);transform:translateY(-1px);box-shadow:0 8px 24px var(--glow)}
.btn-primary:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}
.btn-ghost{background:transparent;color:var(--muted);border:1px solid var(--border);padding:10px 20px;border-radius:10px;font-family:inherit;font-weight:500;font-size:13px;cursor:pointer;transition:.2s}
.btn-ghost:hover{border-color:var(--muted);color:var(--fg)}
.topic-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:24px;cursor:pointer;transition:.25s;position:relative;overflow:hidden}
.topic-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 12px 32px rgba(0,0,0,.4)}
.topic-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--accent);opacity:0;transition:.25s}
.topic-card:hover::before{opacity:1}
.style-card{background:var(--card);border:2px solid var(--border);border-radius:12px;padding:16px;cursor:pointer;transition:.2s;text-align:center}
.style-card:hover{border-color:var(--muted)}
.style-card.active{border-color:var(--accent);box-shadow:0 0 20px var(--glow)}
.progress-bar{width:100%;height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--warn));border-radius:3px;transition:width .15s}
.toast{position:fixed;bottom:24px;right:24px;background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px 20px;font-size:14px;z-index:999;animation:slideIn .3s ease;display:flex;align-items:center;gap:10px;box-shadow:0 12px 40px rgba(0,0,0,.5)}
@keyframes slideIn{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.step-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;display:flex;gap:16px;align-items:flex-start}
.step-num{width:32px;height:32px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex-shrink:0}
.scene-item{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:10px 14px;font-size:13px;display:flex;gap:10px;align-items:flex-start}
.scene-num{color:var(--accent);font-weight:700;font-size:12px;min-width:20px}
.glow-dot{width:8px;height:8px;border-radius:50%;background:var(--success);box-shadow:0 0 8px var(--success);animation:pulse 2s infinite}
.history-row{display:grid;grid-template-columns:40px 1fr 120px 100px;gap:16px;align-items:center;padding:14px 0;border-bottom:1px solid var(--border);font-size:14px}
.sidebar{width:220px;flex-shrink:0;border-right:1px solid var(--border);background:var(--bg2);display:flex;flex-direction:column;padding:16px;gap:8px}
.sidebar-label{display:inline}
@media(max-width:768px){
  .sidebar{width:64px;padding:12px 8px}
  .sidebar-label{display:none}
  .sidebar .text-xs{display:none}
  .editor-grid{grid-template-columns:1fr!important}
  .history-row{grid-template-columns:30px 1fr 80px!important}
  .history-row>:nth-child(4){display:none}
  .topics-grid-custom{grid-template-columns:1fr!important}
}
</style>
</head>
<body>
<div id="app" class="flex h-screen">
<aside class="sidebar">
  <div class="flex items-center gap-3 px-2 mb-6 mt-2">
    <div class="w-9 h-9 rounded-lg bg-[var(--accent)] flex items-center justify-center flex-shrink-0"><i class="fa-solid fa-bolt text-white text-sm"></i></div>
    <div class="sidebar-label"><div class="font-bold text-[15px]">AutoShorts</div><div class="text-[11px] text-[var(--muted)]">Viral Machine</div></div>
  </div>
  <div class="nav-item active" data-view="dashboard"><i class="fa-solid fa-fire w-5 text-center"></i><span class="sidebar-label">Dashboard</span></div>
  <div class="nav-item" data-view="editor"><i class="fa-solid fa-wand-magic-sparkles w-5 text-center"></i><span class="sidebar-label">Editor</span></div>
  <div class="nav-item" data-view="history"><i class="fa-solid fa-clock-rotate-left w-5 text-center"></i><span class="sidebar-label">History</span></div>
  <div class="flex-1"></div>
  <div class="nav-item" data-view="setup"><i class="fa-solid fa-gear w-5 text-center"></i><span class="sidebar-label">YouTube Setup</span></div>
  <div id="conn-status" class="flex items-center gap-2 px-2 py-2 text-[12px] text-[var(--muted)]"><div class="w-2 h-2 rounded-full bg-[var(--muted)] flex-shrink-0"></div><span class="sidebar-label">Not connected</span></div>
</aside>
<main class="flex-1 overflow-y-auto">

  <div id="view-setup" class="hidden p-6 md:p-8 max-w-3xl mx-auto">
    <h1 class="text-3xl font-800 mb-2">YouTube Setup</h1>
    <p class="text-[var(--muted)] mb-8 text-[15px]">One-time setup to connect your YouTube channel. Completely free.</p>
    <div class="bg-[var(--warn)] bg-opacity-10 border border-[var(--warn)] border-opacity-30 rounded-xl p-4 mb-8 text-sm flex gap-3 items-start">
      <i class="fa-solid fa-triangle-exclamation text-[var(--warn)] mt-0.5 flex-shrink-0"></i>
      <div><strong>If hosted on GitHub Pages:</strong> Just open the URL and it works. If running locally, serve via <code class="bg-black/30 px-2 py-0.5 rounded text-xs">python -m http.server 8080</code></div>
    </div>
    <div class="flex flex-col gap-4 mb-8">
      <div class="step-card"><div class="step-num">1</div><div>Go to <a href="https://console.cloud.google.com" target="_blank" class="text-[var(--accent)] underline">console.cloud.google.com</a> and create a new project (free).</div></div>
      <div class="step-card"><div class="step-num">2</div><div>Search for <strong>"YouTube Data API v3"</strong> in the API Library and click <strong>Enable</strong>.</div></div>
      <div class="step-card"><div class="step-num">3</div><div>Go to <strong>Credentials → Create Credentials → OAuth client ID</strong>. Select "Web application".</div></div>
      <div class="step-card"><div class="step-num">4</div><div>Under <strong>Authorized JavaScript origins</strong>, add: <code id="origin-hint" class="bg-black/40 px-2 py-0.5 rounded text-xs select-all"></code></div></div>
      <div class="step-card"><div class="step-num">5</div><div>Copy your <strong>Client ID</strong> and paste it below.</div></div>
    </div>
    <div class="flex gap-3 items-end flex-wrap">
      <div class="flex-1 min-w-[250px]"><label class="text-sm text-[var(--muted)] mb-2 block">Google OAuth Client ID</label>
      <input id="client-id-input" type="text" placeholder="xxxxxxx.apps.googleusercontent.com" class="w-full bg-[var(--bg)] border border-[var(--border)] rounded-lg px-4 py-3 text-sm outline-none focus:border-[var(--accent)] transition font-mono"></div>
      <button id="btn-save-client" class="btn-primary h-[46px]">Save</button>
    </div>
    <div id="connect-section" class="hidden mt-8 pt-8 border-t border-[var(--border)]">
      <p class="mb-4 text-sm text-[var(--muted)]">Client ID saved. Now connect your YouTube channel:</p>
      <button id="btn-connect-yt" class="btn-primary"><i class="fa-brands fa-youtube"></i>Connect YouTube</button>
    </div>
  </div>

  <div id="view-dashboard" class="p-6 md:p-8">
    <div class="flex items-end justify-between mb-8 flex-wrap gap-4">
      <div><h1 class="text-3xl font-800 mb-1">Today's Viral Topics</h1><p class="text-[var(--muted)] text-[15px]" id="today-date"></p></div>
      <button class="btn-ghost" onclick="generateDailyTopics()"><i class="fa-solid fa-rotate-right mr-2"></i>Refresh</button>
    </div>
    <div id="topics-grid" class="topics-grid-custom grid grid-cols-1 md:grid-cols-3 gap-5 mb-10"></div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      <div class="bg-[var(--card)] border border-[var(--border)] rounded-xl p-5"><div class="text-[var(--muted)] text-xs mb-1 uppercase tracking-wider">Videos Made</div><div class="text-2xl font-800" id="stat-videos">0</div></div>
      <div class="bg-[var(--card)] border border-[var(--border)] rounded-xl p-5"><div class="text-[var(--muted)] text-xs mb-1 uppercase tracking-wider">Day Streak</div><div class="text-2xl font-800" id="stat-streak">0</div></div>
      <div class="bg-[var(--card)] border border-[var(--border)] rounded-xl p-5"><div class="text-[var(--muted)] text-xs mb-1 uppercase tracking-wider">Status</div><div class="text-2xl font-800 flex items-center gap-2" id="stat-status"><div class="glow-dot"></div>Ready</div></div>
    </div>
    <div class="mt-8 bg-[var(--card)] border border-[var(--border)] rounded-xl p-5">
      <h3 class="font-600 mb-3 text-sm">Quick Tip</h3>
      <p class="text-[var(--muted)] text-sm leading-relaxed">After uploading, go to YouTube Studio and add a trending audio track from the Audio Library. Videos with trending sounds get significantly more impressions on Shorts. Add hashtags like #shorts #viral #facts in the description.</p>
    </div>
  </div>

  <div id="view-editor" class="hidden p-6 md:p-8">
    <div class="flex items-end justify-between mb-6 flex-wrap gap-4">
      <div><h1 class="text-2xl font-800 mb-1">Video Editor</h1><p class="text-[var(--muted)] text-sm" id="editor-topic-label">Select a topic from Dashboard</p></div>
      <button class="btn-ghost" onclick="showView('dashboard')"><i class="fa-solid fa-arrow-left mr-2"></i>Back</button>
    </div>
    <div class="editor-grid grid gap-8" style="grid-template-columns:auto 1fr">
      <div class="flex flex-col items-center gap-4">
        <canvas id="render-canvas" width="1080" height="1920" style="width:243px;height:432px;background:#000;border-radius:12px"></canvas>
        <div id="render-progress-wrap" class="hidden w-full max-w-[243px]">
          <div class="flex justify-between text-xs text-[var(--muted)] mb-1"><span id="render-status">Rendering...</span><span id="render-pct">0%</span></div>
          <div class="progress-bar"><div class="progress-fill" id="render-fill" style="width:0%"></div></div>
        </div>
        <div id="render-actions" class="flex gap-3 w-full max-w-[243px]">
          <button id="btn-render" class="btn-primary flex-1 text-sm justify-center" disabled onclick="startRender()"><i class="fa-solid fa-film"></i>Render</button>
          <button id="btn-download" class="btn-ghost text-sm hidden" onclick="downloadVideo()"><i class="fa-solid fa-download"></i></button>
          <button id="btn-upload" class="btn-primary flex-1 text-sm justify-center hidden" onclick="uploadToYouTube()"><i class="fa-brands fa-youtube"></i>Upload</button>
        </div>
      </div>
      <div class="flex flex-col gap-6 min-w-0">
        <div>
          <h3 class="font-600 text-sm mb-3 uppercase tracking-wider text-[var(--muted)]">Script</h3>
          <div id="script-list" class="flex flex-col gap-2 max-h-[280px] overflow-y-auto pr-2"></div>
        </div>
        <div>
          <h3 class="font-600 text-sm mb-3 uppercase tracking-wider text-[var(--muted)]">Visual Style</h3>
          <div id="styles-grid" class="grid grid-cols-5 gap-3"></div>
        </div>
        <div>
          <h3 class="font-600 text-sm mb-3 uppercase tracking-wider text-[var(--muted)]">Upload Details</h3>
          <input id="video-title" type="text" placeholder="Video title..." class="w-full bg-[var(--bg)] border border-[var(--border)] rounded-lg px-4 py-3 text-sm outline-none focus:border-[var(--accent)] transition mb-3">
          <textarea id="video-desc" placeholder="Description with #shorts #viral..." rows="2" class="w-full bg-[var(--bg)] border border-[var(--border)] rounded-lg px-4 py-3 text-sm outline-none focus:border-[var(--accent)] transition resize-none"></textarea>
        </div>
      </div>
    </div>
  </div>

  <div id="view-history" class="hidden p-6 md:p-8">
    <h1 class="text-3xl font-800 mb-6">Upload History</h1>
    <div id="history-list" class="flex flex-col"></div>
    <div id="history-empty" class="text-center py-20 text-[var(--muted)]"><i class="fa-solid fa-inbox text-4xl mb-4 block opacity-30"></i>No uploads yet</div>
  </div>

</main>
</div>
<div id="toast-container"></div>

<script>
var TOPICS={
psychology:{name:'Psychology',icon:'fa-brain',color:'#a78bfa',hooks:['Why your brain does THIS without you knowing...','Psychologists are stunned by this discovery...','3 psychology facts that feel illegal to know','Your brain has been lying to you about THIS...','This trick hacks your brain in seconds'],facts:['Your brain can\'t create faces — it only recycles ones you\'ve seen','You remember incomplete tasks better than finished ones','Rejection registers as physical pain in your brain','People who swear more tend to be more honest','Your brain randomly replays embarrassments to prepare you','You can only maintain about 150 real relationships','Your brain deletes useless info while you sleep','Power posing for 2 minutes actually changes your hormones','You\'re more creative when you\'re tired','Your brain uses 20% of your body\'s energy for just 2% of its mass'],ctas:['Follow for more mind-blowing facts','Save this before you forget','Part 2? Comment YES']},
science:{name:'Science',icon:'fa-flask',color:'#38bdf8',hooks:['This science fact breaks the laws of common sense...','Scientists just found something impossible...','The most insane science fact you\'ve never heard','This will make you question reality...','What they don\'t teach you in science class'],facts:['A teaspoon of neutron star weighs 6 billion tons','There are more chess games than atoms in the universe','Hot water can freeze faster than cold water','Light takes 100,000 years to escape the Sun\'s core','A day on Venus is longer than its year','You\'re literally time-traveling right now','Fold paper 42 times and it reaches the Moon','Your DNA could stretch to Pluto and back 17 times','Sound travels 4x faster in water than air','Octopuses have 3 hearts and blue blood'],ctas:['Follow for daily science facts','Share this with a smart friend','Save this for later']},
money:{name:'Money',icon:'fa-dollar-sign',color:'#4ade80',hooks:['Rich people do THIS every single morning...','The money rule nobody talks about...','Why 90% of people will never build wealth','This money trick changed everything for me','Stop doing THIS with your money right now'],facts:['The average millionaire has 7 income streams','78% of NFL players go bankrupt within 3 years','Compound interest is called the 8th wonder of the world','$200/month from age 25 = $500k+ by 65','66% of millennials have zero retirement savings','The average American wastes $1,497/month on non-essentials','A $5 daily coffee habit costs $1,825 per year','23% of adults have absolutely no emergency savings','Starting to invest at 25 vs 35 = hundreds of thousands lost','The richest 1% own more than the bottom 50% combined'],ctas:['Follow to build wealth','Save this — your future self will thank you','Share with someone who needs this']},
