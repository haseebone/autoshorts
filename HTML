};

var STYLES=[
{id:'neon',name:'Dark Neon',bg:'#0a0a0a',accent:'#ff3b30',text:'#ffffff',desc:'Glowing red on black'},
{id:'gradient',name:'Gradient Flow',bg:'#0f0a1a',accent:'#a855f7',text:'#ffffff',desc:'Purple flow'},
{id:'minimal',name:'Clean Light',bg:'#f0f0f0',accent:'#111111',text:'#111111',desc:'White minimal'},
{id:'alert',name:'Red Alert',bg:'#0a0a0a',accent:'#ef4444',text:'#ffffff',desc:'Breaking news'},
{id:'cosmic',name:'Cosmic',bg:'#050a18',accent:'#60a5fa',text:'#e0f0ff',desc:'Deep space blue'}
];

var state={
clientId:localStorage.getItem('yt_client_id')||'',
accessToken:localStorage.getItem('yt_access_token')||'',
currentView:'dashboard',selectedTopic:null,selectedStyle:'neon',
script:[],videoBlob:null,isRendering:false,
history:JSON.parse(localStorage.getItem('ash_history')||'[]')
};

function seededRandom(s){s=s%2147483647;if(s<=0)s+=2147483646;return function(){s=s*16807%2147483647;return(s-1)/2147483646}}
function dailySeed(){var d=new Date();return d.getFullYear()*10000+(d.getMonth()+1)*100+d.getDate()}
function pickRandom(a,r,n){var s=[].concat(a).sort(function(){return r()-0.5});return s.slice(0,n)}
function showToast(m,t){t=t||'info';var c=document.getElementById('toast-container');var ic={info:'fa-circle-info',success:'fa-circle-check',error:'fa-circle-xmark',warn:'fa-triangle-exclamation'};var cl={info:'var(--accent)',success:'var(--success)',error:'#ef4444',warn:'var(--warn)'};var e=document.createElement('div');e.className='toast';e.innerHTML='<i class="fa-solid '+ic[t]+'" style="color:'+cl[t]+'"></i>'+m;c.appendChild(e);setTimeout(function(){e.style.opacity='0';e.style.transition='opacity .3s';setTimeout(function(){e.remove()},300)},3500)}
function wrapText(c,t,m){var w=t.split(' ');var l=[];var ln='';for(var i=0;i<w.length;i++){var test=ln?ln+' '+w[i]:w[i];if(c.measureText(test).width>m&&ln){l.push(ln);ln=w[i]}else ln=test}if(ln)l.push(ln);return l}

function generateDailyTopics(){
var rng=seededRandom(dailySeed());
var cats=Object.keys(TOPICS);
var sel=pickRandom(cats,rng,3);
var grid=document.getElementById('topics-grid');
grid.innerHTML='';
sel.forEach(function(ck){
var cat=TOPICS[ck];
var hook=cat.hooks[Math.floor(rng()*cat.hooks.length)];
var facts=pickRandom(cat.facts,rng,5);
var cta=cat.ctas[Math.floor(rng()*cat.ctas.length)];
var card=document.createElement('div');
card.className='topic-card';
var factsHtml=facts.map(function(f){return '<span class="text-[11px] bg-white/5 px-2 py-1 rounded-md text-[var(--muted)] truncate max-w-full">'+f.slice(0,40)+'...</span>'}).join('');
card.innerHTML='<div class="flex items-center gap-3 mb-4"><div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:'+cat.color+'22;color:'+cat.color+'"><i class="fa-solid '+cat.icon+'"></i></div><span class="text-sm font-600" style="color:'+cat.color+'">'+cat.name+'</span></div><p class="text-[15px] font-600 leading-snug mb-4" style="min-height:48px">'+hook+'</p><div class="flex flex-wrap gap-1.5 mb-4">'+factsHtml+'</div><button class="btn-primary text-sm w-full justify-center topic-use-btn">Use This Topic</button>';
var btn=card.querySelector('.topic-use-btn');
btn.addEventListener('click',function(e){e.stopPropagation();selectTopic(ck,hook,facts,cta)});
grid.appendChild(card);
})}

function selectTopic(catKey,hook,facts,cta){
var cat=TOPICS[catKey];
state.script=[{text:hook,duration:4,type:'hook'}];
facts.forEach(function(f,i){state.script.push({text:f,duration:3.5,type:'fact',index:i+1,total:facts.length})});
state.script.push({text:cta,duration:2.5,type:'cta'});
state.selectedTopic={catKey:catKey,hook:hook,facts:facts,cta:cta};
document.getElementById('video-title').value=hook.replace(/\.\.\./,'')+' #shorts #viral';
document.getElementById('video-desc').value=facts.join('\n')+'\n\n'+cta+'\n\n#shorts #viral #facts #trending #fyp';
document.getElementById('editor-topic-label').textContent=cat.name+' — '+hook.slice(0,50)+'...';
renderScriptList();showView('editor');
document.getElementById('btn-render').disabled=false;
previewFrame(0)}

function renderScriptList(){
var list=document.getElementById('script-list');list.innerHTML='';
var labels={hook:'HOOK',cta:'CTA'};
var colors={hook:'var(--accent)',fact:'var(--muted)',cta:'var(--success)'};
state.script.forEach(function(s){
var lb=s.type==='fact'?'FACT '+s.index+'/'+s.total:labels[s.type];
list.innerHTML+='<div class="scene-item"><span class="scene-num" style="color:'+colors[s.type]+'">'+lb+'</span><span class="text-[var(--fg)]">'+s.text+'</span><span class="ml-auto text-[var(--muted)] text-xs flex-shrink-0">'+s.duration+'s</span></div>'})}

function renderStyleSelector(){
var grid=document.getElementById('styles-grid');grid.innerHTML='';
STYLES.forEach(function(s){
var card=document.createElement('div');
card.className='style-card'+(state.selectedStyle===s.id?' active':'');
card.innerHTML='<div class="w-full h-8 rounded-md mb-2" style="background:'+s.bg+';border:1px solid '+s.accent+'33"></div><div class="text-xs font-600">'+s.name+'</div><div class="text-[10px] text-[var(--muted)]">'+s.desc+'</div>';
card.addEventListener('click',function(){state.selectedStyle=s.id;renderStyleSelector();previewFrame(0)});
grid.appendChild(card)})}

var canvas=document.getElementById('render-canvas');
var ctx=canvas.getContext('2d');
var W=1080,H=1920,FPS=30;
var particles=[];
function generateParticles(n){particles=[];for(var i=0;i<n;i++)particles.push({x:Math.random()*W,y:Math.random()*H,r:Math.random()*3+1,vx:(Math.random()-0.5)*0.5,vy:(Math.random()-0.5)*0.5,a:Math.random()})}
generateParticles(60);

function getStyle(id){for(var i=0;i<STYLES.length;i++)if(STYLES[i].id===id)return STYLES[i];return STYLES[0]}

function renderBackground(style,time){
var s=getStyle(style);
if(style==='neon'){
ctx.fillStyle='#0a0a0a';ctx.fillRect(0,0,W,H);
for(var i=0;i<3;i++){var cx=W/2+Math.sin(time*0.4+i*2.1)*300;var cy=H*0.4+Math.cos(time*0.3+i*1.7)*400;var grad=ctx.createRadialGradient(cx,cy,0,cx,cy,400);grad.addColorStop(0,'rgba(255,59,48,0.08)');grad.addColorStop(1,'rgba(255,59,48,0)');ctx.fillStyle=grad;ctx.fillRect(0,0,W,H)}
particles.forEach(function(p){p.x+=p.vx;p.y+=p.vy;p.a=0.3+Math.sin(time*2+p.x)*0.3;if(p.x<0)p.x=W;if(p.x>W)p.x=0;if(p.y<0)p.y=H;if(p.y>H)p.y=0;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle='rgba(255,59,48,'+Math.max(0,p.a).toFixed(2)+')';ctx.fill()})}
else if(style==='gradient'){
var t=time*0.2;var x1=W*0.5+Math.sin(t)*W*0.3,y1=H*0.3+Math.cos(t*0.7)*H*0.2;var x2=W*0.5+Math.cos(t*0.5)*W*0.3,y2=H*0.7+Math.sin(t*0.3)*H*0.2;var grad=ctx.createLinearGradient(x1,y1,x2,y2);grad.addColorStop(0,'#0f0a1a');grad.addColorStop(0.5,'#1a0a2e');grad.addColorStop(1,'#0a1628');ctx.fillStyle=grad;ctx.fillRect(0,0,W,H);
for(var i=0;i<4;i++){var ox=W/2+Math.sin(time*0.5+i*1.5)*350;var oy=H*0.5+Math.cos(time*0.4+i*2)*500;var g=ctx.createRadialGradient(ox,oy,0,ox,oy,300);g.addColorStop(0,'rgba(168,85,247,'+(0.06+i*0.02).toFixed(2)+')');g.addColorStop(1,'rgba(168,85,247,0)');ctx.fillStyle=g;ctx.fillRect(0,0,W,H)}}
else if(style==='minimal'){
ctx.fillStyle='#f0f0f0';ctx.fillRect(0,0,W,H);ctx.fillStyle='#111111';ctx.fillRect(0,0,12,H);ctx.strokeStyle='rgba(0,0,0,0.04)';ctx.lineWidth=1;for(var y=0;y<H;y+=80){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke()}}
else if(style==='alert'){
ctx.fillStyle='#0a0a0a';ctx.fillRect(0,0,W,H);
for(var y=0;y<H;y+=6){ctx.fillStyle='rgba(239,68,68,'+(0.01+Math.sin(y*0.1+time)*0.01).toFixed(3)+')';ctx.fillRect(0,y,W,2)}
var flash=Math.sin(time*4)>0.7?0.15:0.05;ctx.fillStyle='rgba(239,68,68,'+flash.toFixed(2)+')';ctx.fillRect(0,0,W,8);ctx.fillRect(0,H-8,W,8);ctx.fillRect(0,0,8,H);ctx.fillRect(W-8,0,8,H)}
else if(style==='cosmic'){
ctx.fillStyle='#050a18';ctx.fillRect(0,0,W,H);
particles.forEach(function(p,i){var tw=0.2+Math.sin(time*3+i)*0.3;ctx.beginPath();ctx.arc(p.x,p.y,p.r*0.8,0,Math.PI*2);ctx.fillStyle='rgba(180,200,255,'+Math.max(0,tw).toFixed(2)+')';ctx.fill()});
var nx=W*0.6+Math.sin(time*0.15)*200,ny=H*0.4+Math.cos(time*0.1)*300;var ng=ctx.createRadialGradient(nx,ny,0,nx,ny,600);ng.addColorStop(0,'rgba(96,165,250,0.06)');ng.addColorStop(0.5,'rgba(139,92,246,0.03)');ng.addColorStop(1,'rgba(0,0,0,0)');ctx.fillStyle=ng;ctx.fillRect(0,0,W,H)}}

function renderSceneText(style,text,progress,sceneType,sceneIndex,sceneTotal){
var s=getStyle(style);
var fontSize=sceneType==='hook'?86:sceneType==='cta'?72:78;
var weight=sceneType==='hook'?'800':sceneType==='cta'?'600':'700';
ctx.font=weight+' '+fontSize+'px Outfit, sans-serif';
ctx.textAlign='center';ctx.textBaseline='middle';
var maxW=W*0.8;
var words=text.split(' ');var totalWords=words.length;
var wordsToShow=Math.min(Math.floor(progress*totalWords*1.8)+1,totalWords);
var visibleText=words.slice(0,wordsToShow).join(' ');
var visibleLines=wrapText(ctx,visibleText,maxW);
var lineHeight=fontSize*1.25;var blockH=visibleLines.length*lineHeight;
var startY=H/2-blockH/2+lineHeight/2;

if(style==='neon'){ctx.shadowColor=s.accent;ctx.shadowBlur=20;ctx.fillStyle='#ffffff'}
else if(style==='gradient'){ctx.shadowColor='rgba(168,85,247,0.5)';ctx.shadowBlur=16;ctx.fillStyle='#ffffff'}
else if(style==='minimal'){ctx.shadowColor='transparent';ctx.shadowBlur=0;ctx.fillStyle='#111111'}
else if(style==='alert'){ctx.shadowColor='transparent';ctx.shadowBlur=0;ctx.fillStyle='#ffffff'}
else if(style==='cosmic'){ctx.shadowColor='rgba(96,165,250,0.5)';ctx.shadowBlur=16;ctx.fillStyle='#e0f0ff'}

visibleLines.forEach(function(line,i){var y=startY+i*lineHeight;var slideOffset=Math.max(0,(1-progress*3))*60;ctx.globalAlpha=Math.min(1,progress*3);ctx.fillText(line,W/2,y+slideOffset)});
ctx.globalAlpha=1;ctx.shadowBlur=0;ctx.shadowColor='transparent';

if(sceneType==='fact'&&style!=='minimal'){ctx.font='600 36px Outfit, sans-serif';ctx.fillStyle=style==='minimal'?'rgba(0,0,0,0.2)':'rgba(255,255,255,0.15)';ctx.textAlign='right';ctx.fillText(sceneIndex+' / '+sceneTotal,W-60,H-80);ctx.textAlign='center'}
if(style==='alert'&&sceneType==='fact'){ctx.font='800 32px Outfit, sans-serif';ctx.fillStyle='#ef4444';ctx.textAlign='left';ctx.fillText('FACT #'+sceneIndex,60,100);ctx.textAlign='center'}
if(style==='minimal'){var lineY=startY+visibleLines.length*lineHeight+20;ctx.fillStyle='#111111';ctx.fillRect(W/2-60,lineY,120,4)}}

function renderFrame(time){
ctx.clearRect(0,0,W,H);
renderBackground(state.selectedStyle,time);
var acc=0,sceneIdx=0,sceneTime=0;
for(var i=0;i<state.script.length;i++){if(time<acc+state.script[i].duration){sceneIdx=i;sceneTime=time-acc;break}acc+=state.script[i].duration;if(i===state.script.length-1){sceneIdx=i;sceneTime=state.script[i].duration}}
var scene=state.script[sceneIdx];var sceneProgress=sceneTime/scene.duration;
var fadeIn=Math.min(sceneTime/0.3,1);var fadeOut=Math.min((scene.duration-sceneTime)/0.3,1);
ctx.globalAlpha=Math.min(fadeIn,fadeOut);
renderSceneText(state.selectedStyle,scene.text,sceneProgress,scene.type,scene.index,scene.total);
ctx.globalAlpha=1}

function previewFrame(time){if(!state.script.length)return;generateParticles(60);renderFrame(time)}
function getTotalDuration(){var s=0;state.script.forEach(function(sc){s+=sc.duration});return s}

async function startRender(){
if(state.isRendering||!state.script.length)return;
state.isRendering=true;state.videoBlob=null;
var btnR=document.getElementById('btn-render');var btnD=document.getElementById('btn-download');var btnU=document.getElementById('btn-upload');
var pw=document.getElementById('render-progress-wrap');
btnR.disabled=true;btnD.classList.add('hidden');btnU.classList.add('hidden');pw.classList.remove('hidden');
document.getElementById('render-status').textContent='Rendering...';
generateParticles(60);
var totalDur=getTotalDuration();var totalFrames=Math.ceil(totalDur*FPS);
var mimeType='video/webm;codecs=vp9';
if(!MediaRecorder.isTypeSupported(mimeType)){mimeType='video/webm;codecs=vp8';if(!MediaRecorder.isTypeSupported(mimeType))mimeType='video/webm'}
var stream=canvas.captureStream(FPS);
var recorder=new MediaRecorder(stream,{mimeType:mimeType,videoBitsPerSecond:8000000});
var chunks=[];
recorder.ondataavailable=function(e){if(e.data.size>0)chunks.push(e.data)};
var blob=await new Promise(function(resolve){
recorder.onstop=function(){resolve(new Blob(chunks,{type:'video/webm'}))};
recorder.start(100);
var frame=0;
function loop(){if(frame>=totalFrames){recorder.stop();return}renderFrame(frame/FPS);frame++;var pct=Math.round(frame/totalFrames*100);document.getElementById('render-pct').textContent=pct+'%';document.getElementById('render-fill').style.width=pct+'%';requestAnimationFrame(loop)}
requestAnimationFrame(loop)});
state.videoBlob=blob;state.isRendering=false;
document.getElementById('render-status').textContent='Done';
btnR.disabled=false;btnD.classList.remove('hidden');
if(state.accessToken)btnU.classList.remove('hidden');
showToast('Video rendered — '+(blob.size/1024/1024).toFixed(1)+' MB','success')}

function downloadVideo(){if(!state.videoBlob)return;var a=document.createElement('a');a.href=URL.createObjectURL(state.videoBlob);a.download='short_'+Date.now()+'.webm';a.click();URL.revokeObjectURL(a.href);showToast('Video downloaded','success')}

function updateConnectionStatus(){
var el=document.getElementById('conn-status');
if(state.accessToken){el.innerHTML='<div class="glow-dot flex-shrink-0"></div><span class="sidebar-label">YouTube connected</span>';el.style.color='var(--success)'}
else{el.innerHTML='<div class="w-2 h-2 rounded-full bg-[var(--muted)] flex-shrink-0"></div><span class="sidebar-label">Not connected</span>';el.style.color='var(--muted)'}}

function saveClientId(){
var id=document.getElementById('client-id-input').value.trim();
if(!id){showToast('Please enter a Client ID','error');return}
state.clientId=id;localStorage.setItem('yt_client_id',id);
document.getElementById('connect-section').classList.remove('hidden');
showToast('Client ID saved','success')}

function connectYouTube(){
if(!state.clientId){showToast('Save Client ID first','error');return}
if(typeof google==='undefined'||!google.accounts){showToast('Google Identity Services not loaded. Use a web server.','error');return}
try{var tokenClient=google.accounts.oauth2.initTokenClient({
client_id:state.clientId,
scope:'https://www.googleapis.com/auth/youtube.upload https://www.googleapis.com/auth/youtube.readonly',
callback:function(resp){if(resp.error){showToast('Auth error: '+resp.error,'error');return}state.accessToken=resp.access_token;localStorage.setItem('yt_access_token',resp.access_token);updateConnectionStatus();showToast('YouTube connected successfully','success');if(state.videoBlob)document.getElementById('btn-upload').classList.remove('hidden')}
});tokenClient.requestAccessToken({prompt:'consent'})}
catch(e){showToast('Failed to initialize: '+e.message,'error')}}

async function uploadToYouTube(){
if(!state.videoBlob||!state.accessToken)return;
var btn=document.getElementById('btn-upload');btn.disabled=true;btn.innerHTML='<i class="fa-solid fa-spinner fa-spin"></i>Uploading...';
document.getElementById('render-status').textContent='Uploading to YouTube...';
var pw=document.getElementById('render-progress-wrap');pw.classList.remove('hidden');
document.getElementById('render-pct').textContent='...';document.getElementById('render-fill').style.width='0%';
document.getElementById('render-fill').style.background='var(--success)';
var title=document.getElementById('video-title').value||'Viral Short #shorts';
var desc=document.getElementById('video-desc').value||'';
var metadata={snippet:{title:title,description:desc,categoryId:'22',defaultLanguage:'en'},status:{privacyStatus:'public',selfDeclaredMadeForKids:false,embeddable:true}};
try{
var res=await fetch('https://www.googleapis.com/upload/youtube/v3/videos?uploadType=resumable&part=snippet,status',{method:'POST',headers:{'Authorization':'Bearer '+state.accessToken,'Content-Type':'application/json'},body:JSON.stringify(metadata)});
if(!res.ok){var err=await res.json().catch(function(){});throw new Error((err&&err.error&&err.error.message)||'HTTP '+res.status)}
var uploadUrl=res.headers.get('Location');if(!uploadUrl)throw new Error('No upload URL received');
document.getElementById('render-status').textContent='Uploading video data...';
var xhr=new XMLHttpRequest();
await new Promise(function(resolve,reject){
xhr.upload.onprogress=function(e){if(e.lengthComputable){var pct=Math.round(e.loaded/e.total*100);document.getElementById('render-pct').textContent=pct+'%';document.getElementById('render-fill').style.width=pct+'%'}};
xhr.onload=function(){if(xhr.status>=200&&xhr.status<300){resolve(JSON.parse(xhr.responseText))}else{try{reject(new Error(JSON.parse(xhr.responseText).error.message))}catch(e){reject(new Error('Upload failed '+xhr.status))}}};
xhr.onerror=function(){reject(new Error('Network error'))};
xhr.open('PUT',uploadUrl);xhr.setRequestHeader('Content-Type','video/webm');xhr.send(state.videoBlob)});
state.history.unshift({title:title,date:new Date().toISOString(),status:'uploaded'});
localStorage.setItem('ash_history',JSON.stringify(state.history));
updateStats();renderHistory();
document.getElementById('render-status').textContent='Uploaded!';document.getElementById('render-pct').textContent='100%';document.getElementById('render-fill').style.width='100%';
showToast('Video uploaded to YouTube!','success')}
catch(e){showToast('Upload failed: '+e.message,'error');document.getElementById('render-status').textContent='Upload failed';
if(e.message.indexOf('401')>=0||e.message.indexOf('token')>=0){state.accessToken='';localStorage.removeItem('yt_access_token');updateConnectionStatus()}}
finally{btn.disabled=false;btn.innerHTML='<i class="fa-brands fa-youtube"></i>Upload'}}

function renderHistory(){
var list=document.getElementById('history-list');var empty=document.getElementById('history-empty');
if(!state.history.length){list.innerHTML='';empty.classList.remove('hidden');return}
empty.classList.add('hidden');
var html='<div class="history-row text-xs text-[var(--muted)] uppercase tracking-wider font-600"><span>#</span><span>Title</span><span>Date</span><span>Status</span></div>';
state.history.forEach(function(h,i){html+='<div class="history-row"><span class="text-[var(--muted)]">'+(i+1)+'</span><span class="truncate">'+h.title+'</span><span class="text-[var(--muted)] text-sm">'+new Date(h.date).toLocaleDateString()+'</span><span class="text-[var(--success)] text-sm flex items-center gap-2"><i class="fa-solid fa-circle-check"></i>'+h.status+'</span></div>'});
list.innerHTML=html}

function updateStats(){
document.getElementById('stat-videos').textContent=state.history.length;
var streak=0;var today=new Date();today.setHours(0,0,0,0);
for(var d=0;d<365;d++){var check=new Date(today);check.setDate(check.getDate()-d);var ds=check.toISOString().split('T')[0];if(state.history.some(function(h){return h.date.indexOf(ds)===0}))streak++;else break}
document.getElementById('stat-streak').textContent=streak}

function showView(name){
state.currentView=name;
['setup','dashboard','editor','history'].forEach(function(v){document.getElementById('view-'+v).classList.toggle('hidden',v!==name)});
document.querySelectorAll('.nav-item[data-view]').forEach(function(n){n.classList.toggle('active',n.dataset.view===name)});
if(name==='history')renderHistory();
if(name==='dashboard'){updateStats();generateDailyTopics()}
if(name==='editor')renderStyleSelector()}

function init(){
document.getElementById('today-date').textContent=new Date().toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
document.getElementById('origin-hint').textContent=location.origin||'http://localhost:8080';
if(state.clientId){document.getElementById('client-id-input').value=state.clientId;document.getElementById('connect-section').classList.remove('hidden')}
document.querySelectorAll('.nav-item[data-view]').forEach(function(n){n.addEventListener('click',function(){showView(n.dataset.view)})});
document.getElementById('btn-save-client').addEventListener('click',saveClientId);
document.getElementById('btn-connect-yt').addEventListener('click',connectYouTube);
generateDailyTopics();updateStats();renderHistory();updateConnectionStatus();renderStyleSelector();
ctx.fillStyle='#0a0a0a';ctx.fillRect(0,0,W,H);ctx.font='500 42px Outfit, sans-serif';ctx.fillStyle='#333';ctx.textAlign='center';ctx.fillText('Select a topic to preview',W/2,H/2)}

document.fonts.ready.then(init);
</script>
